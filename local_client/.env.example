# The URL of your remote DeerFlow API
DEERFLOW_API_URL=https://bluesec-multiagent-backend.up.railway.app/api/chat/stream

# Securing the API connection
DEERFLOW_API_KEY=

# Absolute path to your Obsidian Vault directory
OBSIDIAN_VAULT_PATH=C:/path/to/your/Obsidian/Vault

# The name of the markdown file where the chat logs will be saved
OBSIDIAN_NOTE_NAME=DeerFlow_Log.md
